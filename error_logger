import logging
import os
import sys
from logging.handlers import RotatingFileHandler
from datetime import datetime
import traceback

# Default log directory (works even when frozen)
def get_log_directory():
    if getattr(sys, 'frozen', False):
        # If running as compiled exe
        base_dir = os.path.dirname(sys.executable)
    else:
        base_dir = os.path.dirname(os.path.abspath(__file__))

    log_dir = os.path.join(base_dir, "logs")
    os.makedirs(log_dir, exist_ok=True)
    return log_dir


def setup_logger(name="app_logger", log_file="app.log", level=logging.ERROR):
    log_dir = get_log_directory()
    log_path = os.path.join(log_dir, log_file)

    logger = logging.getLogger(name)
    logger.setLevel(level)

    if not logger.handlers:
        handler = RotatingFileHandler(
            log_path,
            maxBytes=5 * 1024 * 1024,  # 5 MB
            backupCount=5,
            encoding="utf-8"
        )

        formatter = logging.Formatter(
            "%(asctime)s | %(levelname)s | %(filename)s:%(lineno)d | %(funcName)s | %(message)s"
        )

        handler.setFormatter(formatter)
        logger.addHandler(handler)

    return logger


logger = setup_logger()


def log_exception(e, context=None):
    """
    Logs full exception details with traceback.
    :param e: Exception object
    :param context: Optional additional info (dict or string)
    """
    exc_type, exc_obj, exc_tb = sys.exc_info()

    fname = os.path.split(exc_tb.tb_frame.f_code.co_filename)[1]
    line_no = exc_tb.tb_lineno

    error_details = {
        "type": str(exc_type.__name__),
        "message": str(e),
        "file": fname,
        "line": line_no,
        "function": exc_tb.tb_frame.f_code.co_name,
        "traceback": traceback.format_exc()
    }

    if context:
        error_details["context"] = context

    logger.error(f"{error_details}")


def log_message(message, level="error"):
    """
    General logging for non-exception events.
    """
    level = level.lower()

    if level == "debug":
        logger.debug(message)
    elif level == "info":
        logger.info(message)
    elif level == "warning":
        logger.warning(message)
    else:
        logger.error(message)


# Optional: global exception hook (catches uncaught exceptions)
def handle_uncaught_exceptions(exc_type, exc_value, exc_traceback):
    if issubclass(exc_type, KeyboardInterrupt):
        sys.__excepthook__(exc_type, exc_value, exc_traceback)
        return

    logger.critical("UNCAUGHT EXCEPTION", exc_info=(exc_type, exc_value, exc_traceback))


def enable_global_exception_logging():
    sys.excepthook = handle_uncaught_exceptions
