import os, re, cv2, numpy as np
from pdf2image import convert_from_bytes, pdfinfo_from_bytes
import pytesseract
from multiprocessing import Pool, cpu_count, freeze_support
import hashlib, pickle, shutil, psutil, time, gc, stat
import configparser

BASE_CACHE_DIR = r"resources\cache"
OUTPUT_DIR = r"resources\image_results"
POPPLER_PATH = r"resources\poppler\Library\bin"
TESSERACT_PATH = r"resources\tesseract\tesseract.exe"
pytesseract.pytesseract.tesseract_cmd = TESSERACT_PATH
config = configparser.ConfigParser()

def get_pdf_hash(file_path):
    with open(file_path, "rb") as f:
        return hashlib.md5(f.read()).hexdigest()

def get_cache_paths(pdf_hash):
    base = os.path.join(BASE_CACHE_DIR, pdf_hash)
    return {
        "base": base,
        "images": os.path.join(base, "images"),
        "ocr": os.path.join(base, "ocr"),
    }

def ensure_dirs(paths):
    os.makedirs(paths["base"], exist_ok=True)
    os.makedirs(paths["images"], exist_ok=True)
    os.makedirs(paths["ocr"], exist_ok=True)

def get_total_pages(pdf_bytes):
    info = pdfinfo_from_bytes(pdf_bytes, poppler_path=POPPLER_PATH)
    return info["Pages"]

def get_pool_size():
    # try:
    #     # Determine usable vCPU in the virtual env. Max value is 2
    #     return min(2, len(psutil.Process().cpu_affinity()))
    # except:
    #     return min(2, cpu_count())
    return 2

def on_rm_error(func, path, exc_info):
    os.chmod(path, stat.S_IWRITE)
    func(path)

def safe_rmtree(path, retries=5, delay=1):
    for _ in range(retries):
        try:
            if os.path.exists(path):
                shutil.rmtree(path, onerror=on_rm_error)
            return
        except PermissionError:
            time.sleep(delay)

def clear_all_cache():
    gc.collect()

    if os.path.exists(OUTPUT_DIR):
        safe_rmtree(OUTPUT_DIR)
    os.makedirs(OUTPUT_DIR, exist_ok=True)

    if os.path.exists(BASE_CACHE_DIR):
        safe_rmtree(BASE_CACHE_DIR)
    os.makedirs(BASE_CACHE_DIR, exist_ok=True)

    gc.collect()

#####

def create_initial_images(file_path, resize=0.5):
    st = time.time()
    clear_all_cache()

    pdf_hash = get_pdf_hash(file_path)
    paths = get_cache_paths(pdf_hash)
    ensure_dirs(paths)

    with open(file_path, "rb") as f:
        pdf_bytes = f.read()

    total_pages = get_total_pages(pdf_bytes)
    batch_size = min(20, total_pages)
    print(f"[INIT] Total pages: {total_pages}")

    config.read("config.ini")
    ocr_dpi = int(config["BRAT_CONFIG"]["ocr_dpi"])

    for start in range(0, total_pages, batch_size):
        end = min(start + batch_size, total_pages)

        pages = convert_from_bytes(
            pdf_bytes,
            dpi=ocr_dpi,
            first_page=start + 1,
            last_page=end,
            poppler_path=POPPLER_PATH
        )

        for i, page in enumerate(pages):
            page_index = start + i
            name = f"page_{page_index+1:03d}.jpg"
            cache_img = os.path.join(paths["images"], name)

            if os.path.exists(cache_img):
                shutil.copy(cache_img, os.path.join(OUTPUT_DIR, name))
                continue

            page_np = np.array(page)
            img = cv2.cvtColor(page_np, cv2.COLOR_RGB2RGBA)
            resized = cv2.resize(img, (0, 0), fx=resize, fy=resize)

            cv2.imwrite(cache_img, resized, [cv2.IMWRITE_JPEG_QUALITY, 50])
            cv2.imwrite(os.path.join(OUTPUT_DIR, name), resized, [cv2.IMWRITE_JPEG_QUALITY, 50])

        del pages
        gc.collect()
    
    print(f"Done in {time.time() - st:.2f}s")

def process_page(args):
    i, page, pattern, paths = args

    ocr_file = os.path.join(paths["ocr"], f"page_{i:03d}.pkl")

    if os.path.exists(ocr_file):
        with open(ocr_file, "rb") as f:
            data = pickle.load(f)
    else:
        page_np = np.array(page)
        gray = cv2.cvtColor(page_np, cv2.COLOR_RGB2GRAY)

        config.read("config.ini")
        gradient = int(config["BRAT_CONFIG"]["gradient"])

        _, thresh = cv2.threshold(gray, gradient, 255, cv2.THRESH_BINARY)

        raw = pytesseract.image_to_data(
            thresh,
            config="--oem 3 --psm 11",
            output_type=pytesseract.Output.DICT
        )

        data = {
            "text": raw["text"],
            "left": raw["left"],
            "top": raw["top"],
            "width": raw["width"],
            "height": raw["height"],
        }

        with open(ocr_file, "wb") as f:
            pickle.dump(data, f)

    # Load cached image (smaller than full page)
    img_path = os.path.join(paths["images"], f"page_{i+1:03d}.jpg")
    image = cv2.imread(img_path)
    overlay = image.copy()

    if pattern:
        for j, word in enumerate(data["text"]):
            w = word.lower()
            if w and pattern.search(w):
                x = int(data["left"][j] * 0.5)
                y = int(data["top"][j] * 0.5)
                w_box = int(data["width"][j] * 0.5)
                h_box = int(data["height"][j] * 0.5)

                cv2.rectangle(overlay, (x, y), (x + w_box, y + h_box), (0, 255, 255), -1)

    result = cv2.addWeighted(overlay, 0.6, image, 0.4, 0)
    return i, result

def get_ocr_result(file_path, search_param):
    st = time.time()

    pdf_hash = get_pdf_hash(file_path)
    paths = get_cache_paths(pdf_hash)
    ensure_dirs(paths)

    if os.path.exists(OUTPUT_DIR):
        shutil.rmtree(OUTPUT_DIR)
    os.makedirs(OUTPUT_DIR, exist_ok=True)

    with open(file_path, "rb") as f:
        pdf_bytes = f.read()

    total_pages = get_total_pages(pdf_bytes)

    pattern = None
    if search_param:
        kws = [k.lower() for k in search_param.split()]
        pattern = re.compile("|".join(map(re.escape, kws)))

    pool_size = get_pool_size()
    batch_size = min(20, total_pages)

    print(f"[OCR] Pages: {total_pages}, Batch: {batch_size}, Pool: {pool_size}")

    config.read("config.ini")
    ocr_dpi = int(config["BRAT_CONFIG"]["ocr_dpi"])
    print(f"Using {ocr_dpi} DPI")

    for start in range(0, total_pages, batch_size):
        end = min(start + batch_size, total_pages)

        pages = convert_from_bytes(
            pdf_bytes,
            dpi=ocr_dpi,
            first_page=start + 1,
            last_page=end,
            poppler_path=POPPLER_PATH
        )

        with Pool(pool_size) as p:
            results = p.map(
                process_page,
                [(start + i, page, pattern, paths) for i, page in enumerate(pages)]
            )

        results.sort(key=lambda x: x[0])

        for i, img in results:
            cv2.imwrite(os.path.join(OUTPUT_DIR, f"page_{i+1:03d}.jpg"),
                        img, [cv2.IMWRITE_JPEG_QUALITY, 50])

        del pages
        gc.collect()

    print(f"Done in {time.time() - st:.2f}s")

if __name__ == "__main__":
    freeze_support()
